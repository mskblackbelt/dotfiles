#!/usr/bin/env bash

showHelp() {
  cat << EOF
  wttr [-hlnv]:

  Show the weather at your current location
      -v,           Show data-rich output

      -l <location> Show weather in a specific location (City or ZIP)

      -n <level>    Set forecast verbosity level (default: 1):
                      0 - Current weather only
                      1 - Current weather + today's forecast
                      2 - Current weather + today's + tomorrow's forecast

      -h,           Show this message.

EOF
}

url="wttr.in"
location=""
verbosity="1"

while getopts ":hl:n:v" options; do
  case "${options}" in
    v)
      url="v2.wttr.in"
      ;;
    l)
      location="$OPTARG"
      ;;
    n)
      if [[ ! "$OPTARG" =~ ^[012]$ ]]; then
        echo "Error: -n requires a verbosity level of 0, 1, or 2." >&2
        exit 1
      fi
      verbosity="$OPTARG"
      ;;
    h)
      showHelp
      exit 0
      ;;
    :)
      echo "Error: -${OPTARG} requires an argument." >&2
      exit 1
      ;;
    *)
      echo "Error: Unknown option -${OPTARG}." >&2
      showHelp
      exit 1
      ;;
  esac
done

request="https://$url/${location// /+}?T$verbosity"
[ "$(tput cols)" -lt 125 ] && request+='&n'

curl "$request"